# ============================================================
# CellTrail Backend 環境變數樣板
# 複製為 .env 後填入實際值
#   cp backend/.env.example backend/.env
# ============================================================

# ---------- 資料庫 ----------
# 本機 docker-compose 預設值：
DATABASE_URL=postgresql://celltrail:celltrail@localhost:5432/celltrail
# Render / Supabase 會給 postgres:// 開頭，程式會自動轉為 postgresql://
# SUPABASE_DB_URL=postgresql://...

# 連線池上限（預設 5）
DB_POOL_MAX=5

# ---------- 快取 / Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT / 安全 ----------
# 生產環境請改為強隨機字串（至少 32 bytes）；可用：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-use-a-strong-random-string

# 身份驗證總開關（2026-04-26 預設改為 true）
#   true  → 完整 JWT 驗證（production 必選；證物系統預設應如此）
#   false → 匿名通行，所有請求視為 admin。**僅限本機開發 / pytest 用**，
#           production 設 false 等於把案件機密直接暴露給網際網路
AUTH_ENABLED=true

# ---------- CORS ----------
# 逗號分隔，不可含尾部 /
# dev port 說明：5500 = VS Code Live Server；5501 = python -m http.server fallback；5173 = Vite
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501,http://127.0.0.1:5173,http://localhost:5173,https://celltrail.netlify.app

# ---------- Google Geocoding ----------
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODE_ENDPOINT=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_REGION=tw
GOOGLE_LANGUAGE=zh-TW

# ---------- OSM Nominatim 備援（可選） ----------
# 設為 1 以啟用；開啟後建議填入聯絡 email 以符合 Nominatim 使用條款
GEO_OSM_FALLBACK=0
NOMINATIM_EMAIL=
